# PostgreSQL
POSTGRES_USER=fivalia
POSTGRES_PASSWORD=fivalia
POSTGRES_DB=fivaliajobs

# Backend
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
NODE_ENV=production

# Origins allowed to call the API (comma-separated)
# Add your Expo dev client URL here, e.g. http://192.168.1.50:8081
ALLOWED_ORIGINS=http://localhost:8081
