generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  WORKER
}

enum PostType {
  NEED
  OFFER
}

enum PostStatus {
  ACTIVE
  CLOSED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  birthDate    DateTime
  rating       Float    @default(0)
  ratingCount  Int      @default(0)
  emailVerified Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile     Profile?
  posts       Post[]
  interests   Interest[]
  favorites   Favorite[]
  following   Follow[]   @relation("Following")
  followers   Follow[]   @relation("Followers")
  reviewsGiven   Review[] @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")
  reports       Report[]   @relation("ReportsFiled")
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  bio       String?
  category  String?
  location  String?
  contact   String?
  photoUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Post {
  id          String     @id @default(cuid())
  userId      String
  type        PostType
  title       String
  description String
  category    String
  status      PostStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  interests Interest[]
  favorites Favorite[]
  reviews   Review[]
}

model Interest {
  id         String   @id @default(cuid())
  fromUserId String
  postId     String

  createdAt DateTime @default(now())

  fromUser User @relation(fields: [fromUserId], references: [id])
  post     Post @relation(fields: [postId], references: [id])

  @@unique([fromUserId, postId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [id])
  following User @relation("Followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

enum ReviewType {
  WORKER_REVIEW
  CLIENT_REVIEW
}

model Review {
  id         String     @id @default(cuid())
  fromUserId String
  toUserId   String
  postId     String
  rating     Int
  comment    String?
  type       ReviewType
  createdAt  DateTime   @default(now())

  fromUser User @relation("ReviewsGiven", fields: [fromUserId], references: [id])
  toUser   User @relation("ReviewsReceived", fields: [toUserId], references: [id])
  post     Post @relation(fields: [postId], references: [id])

  @@unique([fromUserId, postId])
}

enum ReportType {
  REPORT_USER
  REPORT_POST
}

enum ReportReason {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  FAKE
  OTHER
}

model Report {
  id        String       @id @default(cuid())
  fromUserId String
  targetType ReportType
  targetId  String
  reason    ReportReason
  details   String?
  status    String       @default("PENDING")
  createdAt DateTime     @default(now())

  fromUser User @relation("ReportsFiled", fields: [fromUserId], references: [id])

  @@unique([fromUserId, targetType, targetId])
}
